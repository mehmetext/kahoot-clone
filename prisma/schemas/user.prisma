enum UserRole {
  ADMIN
  USER
}

model User {
  id String @id @default(uuid())

  email    String   @unique
  password String
  role     UserRole

  quizzes Quiz[]
  games   Game[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("users")
}
